# Copie para .env e ajuste conforme necessário.

# Postgres
POSTGRES_USER=fishing
POSTGRES_PASSWORD=fishing
POSTGRES_DB=fishingheroes
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend (Go) — hosts "postgres" e "redis" valem dentro do docker compose.
DATABASE_URL=postgres://fishing:fishing@postgres:5432/fishingheroes?sslmode=disable
REDIS_URL=redis://redis:6379
HTTP_ADDR=:8080
HTTP_PORT=8080

# Modo de desenvolvimento: habilita o client de teste em "/" e o fast-forward (ff).
# DEIXE false EM PRODUÇÃO. Para testar localmente com o client, use true.
DEV_MODE=true

# Pool do Postgres (principal gargalo com muitos jogadores simultâneos).
DB_MAX_CONNS=25
DB_MIN_CONNS=2

# CORS: "*" libera todas as origens (conveniente p/ Godot web export em dev).
# Em produção, restrinja para os domínios do seu cliente.
CORS_ORIGINS=*

# Autenticação (contas vinculadas à Steam).
# JWT_SECRET: segredo dos tokens. OBRIGATÓRIO em produção; em DEV_MODE usa um padrão inseguro.
JWT_SECRET=
TOKEN_TTL=720h
# Validação de ticket Steam (produção). Se vazios e DEV_MODE=true, usa login dev (ticket = SteamID).
STEAM_WEB_API_KEY=
STEAM_APP_ID=

# Marketplace: taxa em basis points (1000 = 10%).
MARKET_FEE_BPS=1000
