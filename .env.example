# Copie para .env e ajuste conforme necessário.

# Postgres
POSTGRES_USER=fishing
POSTGRES_PASSWORD=fishing
POSTGRES_DB=fishingheroes
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend (Go)
# Hosts "postgres" e "redis" valem dentro do docker compose.
DATABASE_URL=postgres://fishing:fishing@postgres:5432/fishingheroes?sslmode=disable
REDIS_URL=redis://redis:6379
HTTP_ADDR=:8080
HTTP_PORT=8080
